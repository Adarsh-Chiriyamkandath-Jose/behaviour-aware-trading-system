# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Data — keep code in git, not datasets (regenerate via loader)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Results — keep folders, ignore generated artifacts
results/figures/*
results/tables/*
results/models/*
!results/figures/.gitkeep
!results/tables/.gitkeep
!results/models/.gitkeep

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Env / secrets
.env

# Streamlit runtime logs
streamlit_*.log
